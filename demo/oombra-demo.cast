[19.826657, "o", "{\r\n    \"total_contributions\": 21,\r\n    \"by_type\": {\r\n        \"attack_map\": 6,\r\n        \"eval\": 3,\r\n        \"ioc_bundle\": 12\r\n    },\r\n    \"unique_vendors\": 3\r\n}\r\n"]
[20.837762, "o", "  \r\n"]
[21.649796, "o", "  Pennsylvania, West Virginia, and Michigan already contributed.\r\n"]
[22.462201, "o", "  Ohio doesn't know any of this yet. They just got breached.\r\n"]
[25.281688, "o", "\r\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\r\n"]
[25.282069, "o", "  THE INCIDENT: What Ohio's IR team pulled from their network\r\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\r\n"]
[27.295171, "o", "  4 IOCs from the compromised EHR servers:\r\n"]
[28.107627, "o", "    - lockbit-decryptor.onion.ws (C2 domain)\r\n"]
[28.926297, "o", "    - a1b2c3...123456 (LockBit payload hash)\r\n"]
[29.742808, "o", "    - 45.33.32.156 (attacker IP)\r\n"]
[30.557045, "o", "    - lockbit-support@protonmail.com (ransom contact)\r\n"]
[31.371353, "o", "  \r\n"]
[32.18495, "o", "  They can't share this raw — HIPAA, internal network context.\r\n"]
[32.99795, "o", "  But they NEED to know if this is part of something bigger.\r\n"]
[35.822185, "o", "\r\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\r\n  \"Are we the only ones getting hit?\"\r\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\r\n"]
[37.836397, "o", "  One command. IOCs anonymized locally, then analyzed against\r\n"]
[38.648374, "o", "  what Pennsylvania, West Virginia, and Michigan contributed.\r\n"]
