[0.315875, "o", "\u001b[H\u001b[J"]
[0.316311, "o", "\r\n  ┌───────────────────────────────────────────────────────┐\r\n  │                                                       │\r\n  │   2:17 AM — Ohio Children's Hospital                  │\r\n  │                                                       │\r\n  │   EHR system encrypted. LockBit ransom note on        │\r\n  │   every screen. NICU monitors offline.                │\r\n  │                                                       │\r\n  │   The IR team has IOCs and MITRE observations.        │\r\n  │   They need to know: is anyone else seeing this?      │\r\n  │   What are they missing? What should they do next?    │\r\n  │                                                       │\r\n  │   To get answers, they have to contribute.            │\r\n  │                                                       │\r\n  └────────────────────"]
[0.316396, "o", "───────────────────────────────────┘\r\n\r\n"]
[5.325041, "o", "  The oombra platform already has contributions from 3 other hospitals\r\n"]
[6.13762, "o", "  and real IOCs scraped from ThreatFox, Feodo Tracker, and CISA KEV.\r\n"]
