[57.296607, "o", "spec_version = \"0.2.3\"\r\n\r\nthreatmodel \"Organization Healthcare & Life Sciences Security Stack\" {\r\n  description = \"Threat model for Organization using CrowdStrike Falcon, Splunk Enterprise Security\"\r\n  author = \"nur\"\r\n\r\n  attributes {\r\n    new_initiative = \"false\"\r\n    internet_facing = \"true\"\r\n    initiative_size = \"Medium\"\r\n  }\r\n\r\n  information_asset \"primary_data\" {\r\n    description = \"Electronic Health Records (EHR), PACS imaging, patient PII\"\r\n    information_classification = \"Confidential\"\r\n  }\r\n\r\n  information_asset \"network_infrastructure\" {\r\n    description = \"NICU monitors, medical devices, clinical workstations\"\r\n    information_classification = \"Internal\"\r\n"]
[60.325818, "o", "\r\n"]
[60.325851, "o", "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\r\n\r\n  WARTIME                PEACETIME              THREAT MODEL\r\n  nur report iocs.json   nur market edr         nur threat-model\r\n  nur report attack.json nur search compare X Y   --stack X,Y,Z\r\n  nur report eval.json   nur threat-map '...'     --hcl > model.hcl\r\n\r\n"]
